    <!-- Inquiry -->
    <section id="inquiry" class="py-32 px-8 md:px-24 bg-black">
        <div class="max-w-4xl mx-auto glass p-12 md:p-24 border-t border-white/10">
            <h2 class="font-sync text-2xl font-bold mb-12 italic text-center">PROJECT INITIATION</h2>
            <form onsubmit="handleForm(event)" class="grid md:grid-cols-2 gap-8">
                <input type="text" placeholder="PARTNER NAME" class="p-4 bg-white/5 border border-white/10 text-xs outline-none" required>
                <select class="p-4 bg-white/5 border border-white/10 text-xs appearance-none"><option>Urbanization</option><option>Industrial</option><option>Bespoke Housing</option></select>
                <textarea rows="5" placeholder="TECHNICAL VISION" class="md:col-span-2 p-4 bg-white/5 border border-white/10 text-xs outline-none"></textarea>
                <button type="submit" class="md:col-span-2 py-6 bg-white text-black font-bold uppercase tracking-[0.4em] text-[10px] hover:bg-gray-200 transition">Initiate Brief</button>
            </form>
        </div>
    </section>

    <!-- Press Hub -->
    <section id="press" class="py-32 px-8 md:px-24 bg-[#0d0d0d] border-t border-white/5">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
            <div><h2 class="font-sync text-xl mb-4 italic">PRESS HUB</h2><p class="text-[10px] text-gray-600 uppercase tracking-widest">Download our 2026 Studio Press Kit for high-resolution assets.</p></div>

            <button onclick="downloadPortfolio()" class="px-10 py-4 border border-white/30 text-[10px] uppercase tracking-widest font-bold hover:bg-white hover:text-black transition">Download Press Kit (.TXT)</button>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-24 px-8 border-t border-white/5 bg-[#0a0a0a]">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16">
            <div><h2 class="font-sync text-xl font-bold mb-6 italic text-white/90">I / A STUDIOS</h2><p class="text-[8px] text-gray-600 uppercase tracking-widest">tankitsibela10@gmail.com • +266 57599239<br>MASERU • LESOTHO</p></div>
            <div class="space-y-4">
                <h4 class="font-sync text-[9px] uppercase tracking-widest text-gray-400">Navigation</h4>
                <ul class="text-[9px] text-gray-600 uppercase space-y-2">
                    <li><a href="#philosophy" class="hover:text-white transition">Philosophy</a></li>
                    <li><a href="#services" class="hover:text-white transition">Services</a></li>
                    <li><a href="#awards-shelf" class="hover:text-white transition">Awards</a></li>
                    <li><a href="#spaces" class="hover:text-white transition">Portfolio</a></li>
                </ul>
            </div>
            <div class="text-[9px] text-gray-700 uppercase tracking-widest">
                <a href="https://www.facebook.com" target="_blank" class="hover:text-white transition font-bold">Facebook Profile</a>

                <p class="mt-4">© 2026 INNOVATIVE ARCHYTECH STUDIOS.<br>Registration: MAS/2026/ARC</p>
            </div>
        </div>
    </footer>

    <script>
        let currentKey = 'admin123';
        let isLoggedIn = false;
        let uploadedAssets = [];

        function showLogin() { document.getElementById('loginOverlay').style.display = 'flex'; }
        function closeLogin() { document.getElementById('loginOverlay').style.display = 'none'; document.getElementById('passInput').value = ''; document.getElementById('loginError').classList.add('hidden'); }
        function closeSuccess() { document.getElementById('successOverlay').style.display = 'none'; }

        function attemptLogin() {
            const input = document.getElementById('passInput').value;
            if (input === currentKey) { isLoggedIn = true; updateUIPrivileges(); closeLogin(); }
            else { document.getElementById('loginError').classList.remove('hidden'); }
        }


        function logout() { isLoggedIn = false; updateUIPrivileges(); }

        function updateKey() {
            const val = document.getElementById('newKeyInput').value;
            if (val) { currentKey = val; alert('Studio Security Key Updated.'); document.getElementById('newKeyInput').value = ''; }
        }

        function updateUIPrivileges() {
            const locked = document.getElementById('lockedControls');
            const unlocked = document.getElementById('unlockedControls');
            const adminPanel = document.getElementById('admin-panel');
            const navLink = document.getElementById('adminNavLink');
            const badge = document.getElementById('adminBadge');

            if (isLoggedIn) {
                locked.classList.add('hidden'); unlocked.classList.remove('hidden');
                adminPanel.classList.remove('hidden'); navLink.classList.remove('hidden');
                badge.innerText = 'Admin Authorized'; badge.classList.add('bg-green-500/20');
            } else {

                locked.classList.remove('hidden'); unlocked.classList.add('hidden');
                adminPanel.classList.add('hidden'); navLink.classList.add('hidden');
                badge.innerText = 'Studio Login'; badge.classList.remove('bg-green-500/20');
            }
        }

        function addProjectRow() {
            if (!isLoggedIn) return;
            const list = document.getElementById('projectList');
            const div = document.createElement('div');
            div.className = 'border-b border-white/5 pb-8 relative group';
            div.innerHTML = `
                <div class="flex justify-between items-center mb-6">
                    <input type="text" placeholder="PROJECT NAME" class="bg-transparent border-none text-[10px] font-bold uppercase tracking-widest outline-none text-white w-1/2">
                    <button onclick="this.parentElement.parentElement.remove()" class="text-[7px] text-red-500/50 uppercase">Delete</button>
                </div>
                <div class="flex justify-between relative px-2">
                    <div class="absolute top-[5px] left-0 right-0 h-[1px] bg-white/10 -z-10 mx-6"></div>
                    ${['Inception','Concept','Design Dev','Docs','Construction','Closeout'].map((s,i) => `

                        <div class="flex flex-col items-center gap-3 cursor-pointer" onclick="toggleNode(this)">
                            <div class="progress-node"></div>
                            <span class="text-[7px] uppercase text-gray-600">${s}</span>
                        </div>
                    `).join('')}
                </div>
            `;
            list.appendChild(div);
        }

        function toggleNode(el) {
            if (!isLoggedIn) return;
            const node = el.querySelector('.progress-node');
            const text = el.querySelector('span');
            node.classList.toggle('active');
            text.classList.toggle('text-white');
            text.classList.toggle('text-gray-600');
        }


        document.getElementById('imageInput').addEventListener('change', (e) => {
            if (!isLoggedIn) return;
            const files = e.target.files;
            const liveGallery = document.getElementById('liveGallery');
            if (files.length > 0) {
                if (liveGallery.querySelector('span')) liveGallery.innerHTML = '';
                Array.from(files).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        const assetId = Date.now() + Math.random();
                        const div = document.createElement('div');
                        div.className = 'glass p-4 rounded-sm flex flex-col gap-4';
                        div.innerHTML = `
                            <img src="${event.target.result}" class="aspect-square w-full object-cover">
                            <input type="text" placeholder="EMBODIED CARBON (KgCO2e/m²)" class="bg-[#d4af37]/5 border border-[#d4af37]/20 p-2 text-[7px] outline-none text-[#d4af37]" oninput="updateMeta(${assetId}, 'carbon', this.value)">
                            <textarea placeholder="AWARD STORY (Brief → Challenge → Solution)" class="bg-white/5 border border-white/10 p-2 text-[8px] outline-none h-20" oninput="updateMeta(${assetId}, 'story', this.value)"></textarea>
                            <button onclick="removeAsset(${assetId}, this)" class="text-[7px] uppercase tracking-widest text-red-500/60 text-left">Remove</button>
                        `;
                        liveGallery.appendChild(div);

                        uploadedAssets.push({ id: assetId, name: file.name, carbon: '', story: '' });
                    };
                    reader.readAsDataURL(file);
                });
            }
        });

        function updateMeta(id, field, val) { const asset = uploadedAssets.find(a => a.id === id); if (asset) asset[field] = val; }
        function removeAsset(id, btn) { uploadedAssets = uploadedAssets.filter(a => a.id !== id); btn.parentElement.remove(); }
        function resetGallery() { uploadedAssets = []; document.getElementById('liveGallery').innerHTML = '<div class="aspect-square glass flex items-center justify-center border-dashed border-2 border-white/5 opacity-10"><span class="text-[9px] uppercase tracking-widest italic">Submission Portfolio Ready</span></div>'; }

        function downloadPortfolio() {
            let content = "INNOVATIVE ARCHYTECH STUDIOS - PRESS KIT & AWARD MANIFEST 2026\n";
            content += "SESSION DATE: March 9, 2026\n";
            content += "FIRM: Innovative Archytech Studios | Maseru, Lesotho\n\n";
            uploadedAssets.forEach(a => { 
                content += `PROJECT: ${a.name}\n`;
                content += `CARBON: ${a.carbon || "TBD"} KgCO2e/m²\n`;
                content += `STORY: ${a.story || "No narrative provided"}\n`;

                content += `--------------------------------------------------------\n`;
            });
            const blob = new Blob([content], { type: 'text/plain' });
            const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'IA_Studios_PressKit_2026.txt'; a.click();
        }

        function handleForm(e) { e.preventDefault(); document.getElementById('successOverlay').style.display = 'flex'; }
    </script>
</body>
</html>


